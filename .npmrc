store-dir=.pnpm-store
strict-peer-dependencies=false
# Expo + Metro + Babel resolve modules with a custom mapper that doesn't follow
# pnpm's isolated (symlinked) node_modules — babel-preset-expo and its sub-plugins
# fail to resolve. Hoisting node_modules flat (the Expo-recommended pnpm setup)
# makes the whole RN/Babel/Metro toolchain resolvable. Next.js is unaffected.
node-linker=hoisted
