# apps/mobile environment template — copy to `.env` and fill in.
#
# Expo embeds `EXPO_PUBLIC_*` variables into the JS bundle at build
# time, so changes require restarting Metro (`pnpm --filter
# @eeatly/mobile start --clear`). EAS Build profiles in eas.json also
# set these at build time; the file here is for local dev only.

# Where the mobile app talks to the eeatly API. iOS Simulator can
# reach `localhost`, but a physical device cannot — set this to the
# Mac's LAN IP (e.g. `http://192.168.1.42:3000`) when running on a
# real phone against a local dev server.
#
# Production builds get the deployed URL via the `preview` /
# `production` EAS profiles (see eas.json).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
