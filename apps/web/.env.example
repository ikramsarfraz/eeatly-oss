# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret
PLATFORM_ADMIN_HOST=admin.localhost:3000

# Database: Neon serverless Postgres
# Used by the app at build + runtime, and by the Vercel build-time migration
# step (scripts/migrate-if-target.mjs). Locally, point it at your personal dev
# database. In Vercel, set it per environment: prod DB on Production, uat DB on
# Preview.
DATABASE_URL=postgresql://user:password@ep-name-123456-pooler.us-east-1.aws.neon.tech/eeatly?sslmode=require

# Restricted (non-owner) role for Row-Level Security. OPTIONAL: leave unset to
# keep RLS dormant (the app falls back to DATABASE_URL). Set it ONLY after
# provisioning the role + applying db/rls/*.sql. See db/rls/README.md.
# DATABASE_URL_APP=postgresql://eeatly_app:password@ep-name-123456-pooler.us-east-1.aws.neon.tech/eeatly?sslmode=require

# Email: Resend + React Email
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=CookLoop <hello@cookloop.example>
RESEND_WEBHOOK_SECRET=

# AI providers (both required)
OPENAI_API_KEY=sk-proj-xxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Upstash Redis — backs rate limiting. Optional: leave both unset for local
# dev and the limiters no-op (requests pass through unthrottled). Set both in
# uat/prod (each environment its own database) to enforce the abuse guards.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://pub-example.r2.dev

# Google OAuth (optional — enables "Continue with Google" on sign-in/sign-up)
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel Cron secret (optional — required to enable /api/cron/lifecycle).
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` automatically.
CRON_SECRET=

# Sentry error tracking (optional — SDK is inert without a DSN).
# DSN is public/safe to expose. SENTRY_AUTH_TOKEN only enables
# source-map upload at build time; SENTRY_ENVIRONMENT tags events
# (server + edge). For UAT, also set NEXT_PUBLIC_SENTRY_ENVIRONMENT so
# browser-side errors are tagged correctly; omit it in prod (NODE_ENV
# already resolves to "production" there).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# PostHog product analytics (optional — inert without the token).
# The project token is public/safe to expose. HOST defaults to US cloud; use
# https://eu.i.posthog.com for EU projects. Events are proxied through
# /ingest (next.config rewrites) so ad-blockers don't undercount.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
